# BalanceX Environment Variables
# Copy this file to .env and fill in your values

# Database - PostgreSQL connection string
# Special characters in password must be URL-encoded
# e.g. @ -> %40, % -> %25
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/balancex?schema=public"

# NextAuth.js Configuration
# Set to your server's domain or IP (include port if not 80/443)
NEXTAUTH_URL="http://your-server-ip-or-domain"

# Generate a strong secret: openssl rand -hex 32
NEXTAUTH_SECRET="replace-with-a-strong-random-secret"
